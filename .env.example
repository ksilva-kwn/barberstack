# =============================================================================
# BARBERSTACK - Environment Variables Example
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# --- DATABASE ---
DATABASE_URL="postgresql://barberstack:password@localhost:5432/barberstack_dev"

# --- JWT ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# --- SERVICES PORTS ---
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
BARBERSHOP_SERVICE_PORT=3002
APPOINTMENT_SERVICE_PORT=3003
SUBSCRIPTION_SERVICE_PORT=3004
PAYMENT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# --- SERVICE URLS (internal Docker network) ---
AUTH_SERVICE_URL="http://auth-service:3001"
BARBERSHOP_SERVICE_URL="http://barbershop-service:3002"
APPOINTMENT_SERVICE_URL="http://appointment-service:3003"
SUBSCRIPTION_SERVICE_URL="http://subscription-service:3004"
PAYMENT_SERVICE_URL="http://payment-service:3005"
NOTIFICATION_SERVICE_URL="http://notification-service:3006"

# --- ASAAS (Pagamentos) ---
ASAAS_ENV="sandbox"  # sandbox | production
ASAAS_API_URL_SANDBOX="https://sandbox.asaas.com/api/v3"
ASAAS_API_URL_PRODUCTION="https://api.asaas.com/v3"
ASAAS_MASTER_API_KEY="$aact_your_master_api_key_here"

# --- WHATSAPP / NOTIFICAÇÕES ---
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# --- FRONTEND ---
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3100"

# --- AWS (usado apenas em produção / Terraform) ---
AWS_REGION="us-east-1"
AWS_ACCOUNT_ID=""
